# Top-level .env consumed by docker-compose.yml and docker-compose.prod.yml.
# Copy to .env and adjust before `docker compose up`.

# --- Postgres ---
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker
POSTGRES_DB=tracker
# Prisma connection pool size, appended to DATABASE_URL by compose. Prisma's
# implicit default is cpu*2+1 (≈5 on a 2-core VM, which the admin "Server
# sessions" graph caps at); raise toward 10–15 on a busy small server.
DB_CONNECTION_LIMIT=10

# --- Backend (overrides defaults inside the container) ---
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# Generate strong secrets for prod: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

THROTTLE_TTL=60
THROTTLE_LIMIT=120
# Stricter per-IP throttle for auth routes (login/register/refresh). Defaults to
# 10/60s. Raise both (e.g. 2000000) ONLY for load testing, then revert — these
# limits are what stops credential-stuffing in normal operation.
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=10

# Queries slower than this many ms are surfaced in the admin metrics panel.
SLOW_QUERY_MS=300
# How long (ms) the admin panel caches DB-derived metrics (storage, sessions).
METRICS_CACHE_TTL_MS=30000

# Path (inside the backend container) to the backup job's status file, surfaced
# on /admin/metrics. In prod it's a read-only bind mount of the host file the
# restic job writes. The restic repo + password live ON THE HOST (systemd unit),
# never in this .env — see BACKUPS.md.
BACKUP_STATUS_FILE=/backup-status.json

# Build provenance shown in the admin "Build info" panel. In prod these are
# injected at image build time (docker --build-arg); locally they're optional.
# APP_VERSION=dev
# GIT_SHA=unknown
# BUILD_TIME=unknown

# --- Object storage (MinIO / S3) for task attachments ---
# In dev these default to the MinIO container's root credentials. For prod set
# S3_ACCESS_KEY / S3_SECRET_KEY via GitHub Secrets (the deploy workflow writes
# them into .env, and MinIO is initialised with the same pair). To point at real
# AWS S3 instead of MinIO: set S3_ENDPOINT to the AWS endpoint (or leave empty),
# S3_FORCE_PATH_STYLE=false, and use real AWS keys.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tracker-attachments
S3_REGION=us-east-1
# Max upload size in bytes (default 25 MB). Keep edge nginx client_max_body_size
# (deploy/edge.conf) at or above this.
MAX_UPLOAD_BYTES=26214400

# --- Frontend build arg (DEV ONLY) ---
# Used by docker-compose.yml as a build arg. The frontend Dockerfile bakes this
# into the bundle at build time — it does NOT apply to prod, since prod pulls
# pre-built images. For prod, set the GitHub repo variable VITE_API_URL instead;
# the build job of dev-cd.yml / prod-cd.yml injects it into the image build.
VITE_API_URL=http://localhost:3000/api

# --- Production (docker-compose.prod.yml only) ---
# Docker Hub namespace where images are pushed by CI. Must match the secret
# DOCKERHUB_USERNAME configured in GitHub Actions.
DOCKERHUB_USERNAME=your-dockerhub-username
# Tag to deploy. On each push the CI/CD workflow pushes :sha-<short> and the
# moving environment tag (:dev or :prod); :latest is intentionally not
# published. The deploy job always sets IMAGE_TAG to the concrete :sha-<short>;
# pin to a sha-* tag for predictable rollbacks rather than a moving tag.
IMAGE_TAG=sha-XXXXXXX
