# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# --- Database ---
# Used by Prisma. Format: postgresql://user:password@host:port/db?schema=public
DATABASE_URL=postgresql://tracker:tracker@localhost:5432/tracker?schema=public

# --- Redis (cache + rate-limit) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
# Generate strong values for prod: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Rate limit ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120
